# ─── Elevate Backend Environment ───────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env` to version control.

# Runtime
NODE_ENV=development
PORT=3001

# Origin allowed by CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173

# ─── Secrets (REQUIRED in production) ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 chars in production. Rotating it invalidates all sessions.
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# ─── Database ──────────────────────────────────────────────────────────────
# Local SQLite path (development).
# In production on Fly.io, set this to /data/elevate.db (the persistent
# volume mount point). The docker image already defaults to that.
DB_PATH=../database/jokel.db

# Postgres / Supabase (when migrating off SQLite — currently NOT used at
# runtime, the schema is applied for forward-compat; see docs/SECURITY.md).
# DATABASE_URL=postgres://user:pass@host:5432/elevate

# ─── Storage backend ───────────────────────────────────────────────────────
# Where uploads (avatars, attachments, workspace logos, backgrounds) go.
#   local    → backend/uploads/  (default; survives restarts only on a
#              persistent volume)
#   supabase → Supabase Storage  (recommended for production deploys)
STORAGE_BACKEND=local

# ─── Supabase (only required when STORAGE_BACKEND=supabase) ────────────────
# Project URL: Supabase dashboard → Project Settings → API
# Service role key: same page; SERVER ONLY, never ship to the browser.
# Bucket name: create a private bucket in Supabase Storage with this name.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=elevate

# ─── Optional ──────────────────────────────────────────────────────────────
# Audit log toggle (set false to suppress console audit lines)
AUDIT_LOG_ENABLED=true
# Demo seed password (only used by `npm run seed` in development)
DEMO_PASSWORD=ChangeMe-Dev-Only

# ─── Single sign-on (OAuth) ────────────────────────────────────────────────
# Leave blank to disable a provider. /auth/oauth/providers only advertises
# providers that have BOTH client id + secret set, so the frontend hides
# buttons that aren't wired up.
#
# Google: https://console.cloud.google.com/apis/credentials
#   - Create an "OAuth client ID" of type "Web application"
#   - Authorized redirect URI:
#       http://localhost:3001/api/v1/auth/oauth/google/callback
#       https://api.your-domain/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
#   - "New OAuth App"
#   - Authorization callback URL:
#       http://localhost:3001/api/v1/auth/oauth/github/callback
#       https://api.your-domain/api/v1/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
