{
  "name": "Elevate-backend",
  "version": "1.0.0",
  "description": "Elevate backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "echo \"backend has no compile step; spec was regenerated by prebuild\"",
    "prebuild": "npm run openapi:generate",
    "seed": "node src/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "openapi:generate": "node src/openapi/generate.js",
    "openapi:check": "node src/openapi/check.js"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "uuid": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
