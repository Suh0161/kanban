# Production origins — required for `npm run build` (see vite/validateElevateEnv.js).
# Local `npm run dev` ignores these for navigation and uses `.env.development`
# (localhost:5174 site, :5173 app, :3001/api/docs) unless you override with
# explicit http://localhost:* values in `.env.development.local`.
VITE_SITE_URL=https://arcnvd.com
VITE_APP_URL=https://app.arcnvd.com
VITE_DOCS_URL=https://app.arcnvd.com/api/docs
