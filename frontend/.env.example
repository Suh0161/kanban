# ─── Elevate Frontend Environment ──────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env`.
#
# IMPORTANT: anything prefixed with VITE_ is shipped to the browser bundle.
# Never put secrets, service-role keys, or anything you wouldn't paste on
# Twitter behind a `VITE_` variable.

# Backend API base. Includes the version segment.
VITE_API_BASE=http://localhost:3001/api/v1

# ─── If using Supabase from the browser (optional) ─────────────────────────
# VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=ey...   # safe — RLS restricts what the anon key can do
